# ──────────────────────────────────────────────────────────────
# .env.example — CONTRATO canônico de variáveis (SPEC-000 §2/§7). Versionado no git.
# Copie para .env.local e preencha. NUNCA coloque valores reais aqui.
# NEXT_PUBLIC_* vão ao browser: nada secreto. Em prod: fly secrets (runner) / Vercel env (dashboard).
# Meta Marketing API NÃO usa env: autentica via MCP `mcp-meta-ads` no Claude Code.
# ──────────────────────────────────────────────────────────────

# Anthropic (Claude) — LLM de decisão/voz + Claude Code CLI
CLAUDE_API_KEY=
# OAuth do CLI no runner é feito via `claude login` (volume persistente no Fly), não por env.

# OpenAI — gpt-image-2 (imagem) + Whisper (STT)
OPENAI_API_KEY=

# Supabase — Postgres + Storage + Auth
SUPABASE_URL=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=

# Upstash Redis — cache + rate limit + idempotência
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash — scheduler dinâmico (opcional)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Cloudflare — Pages (landing pages) + Worker (tracking) + DNS + Turnstile
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# ElevenLabs — TTS (voz do Nexus)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Picovoice — wake word ("Nexus")
PICOVOICE_ACCESS_KEY=
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=

# Resend — email do modo autônomo (opcional)
RESEND_API_KEY=
AUTONOMOUS_NOTIFY_EMAIL=
AUTONOMOUS_FROM_EMAIL=

# Telegram — notificação das análises (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard — auth
DASHBOARD_PASSWORD=          # hash SHA-256 da senha (não a senha em texto)
AUTH_SECRET=                 # ≥32 bytes aleatórios (ex.: openssl rand -base64 48)

# Nexus — modelos (default no código: claude-sonnet-4-6)
NEXUS_MODEL=claude-sonnet-4-6
NEXUS_REVIEW_MODEL=claude-sonnet-4-6
