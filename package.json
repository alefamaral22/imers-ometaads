{
  "name": "meta-ads-agents",
  "version": "0.0.0",
  "private": true,
  "description": "Agência de tráfego Meta Ads 100% operada por IAs (SPEC-000).",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "web",
    "packages/*",
    "landing-pages/*",
    "worker/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.8.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.1.3"
  }
}
