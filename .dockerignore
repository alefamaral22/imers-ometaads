# Contexto de build do runner (Onda 3). Mantém o contexto enxuto e — crítico — impede que a
# node_modules do host (Windows) sobrescreva a instalada para Linux no `npm ci` da imagem.

# Dependências (a imagem roda `npm ci` internamente para Linux).
node_modules/
**/node_modules/

# Histórico e tooling de VCS.
.git/
.gitignore
.gitattributes

# Segredos — NUNCA entram na imagem.
.env
.env.*
!.env.example

# Saídas de build dos workspaces.
web/.next/
web/out/
landing-pages/**/.next/
landing-pages/**/out/
packages/**/dist/
**/.turbo/

# Logs e temporários.
logs/
*.log
venv/

# Artefatos locais que o runner não usa.
coverage/
.vercel/
tentativas-geracao-de-campanhas/
